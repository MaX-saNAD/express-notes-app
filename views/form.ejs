<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Notes App</title>
    <link rel="stylesheet" href="/style/style.css" />
  </head>
  <body>
    <div class="form">
      <div class="container">
        <form action="/add" method="post">
          <input
            type="text"
            name="title"
            id="title"
            class="acting-h1"
            placeholder="Title"
            required
          />

          <textarea
            id="body"
            name="body"
            rows="10"
            cols="50"
            placeholder="Start typing your note here..."
            required
            class="acting-p"
          ></textarea>
          <div class="btns">
            <button type="submit" class="send-btn">Add</button>
                      <a href="/" class="send-btn">Return</a>

          </div>
        </form>
      </div>
    </div>
  </body>
</html>
